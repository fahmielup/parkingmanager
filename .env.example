# Konfigurasi aplikasi Parking Manager
# Salin fail ini kepada .env dan isi nilai yang betul.

# Port untuk Flask development server
PORT=5001

# PostgreSQL connection string (Neon, Render, etc.)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Secret keys
SECRET_KEY=change-me-to-random-string
JWT_SECRET=change-me-to-random-string

# CORS: comma-separated list of allowed origins (Netlify URL)
CORS_ORIGINS=https://your-netlify-site.netlify.app

# Konfigurasi Gmail SMTP untuk reset kata laluan
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=amieecompany@gmail.com
SMTP_PASSWORD=aaaa bbbb cccc dddd
RESET_EMAIL_RECIPIENT=amieecompany@gmail.com
APP_BASE_URL=http://127.0.0.1:5001
